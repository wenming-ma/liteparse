{
  "name": "liteparse",
  "version": "1.0.0",
  "description": "Open-source PDF parsing with spatial text extraction and OCR processing",
  "type": "module",
  "main": "./dist/src/lib.js",
  "types": "./dist/src/lib.d.ts",
  "bin": {
    "lp": "./dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/lib.d.ts",
      "import": "./dist/src/lib.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/vendor/pdfjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-vendor",
    "copy-vendor": "mkdir -p dist/src/vendor && cp -r src/vendor/pdfjs dist/src/vendor/",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@hyzyla/pdfium": "^2.1.9",
    "axios": "^1.7.0",
    "canvas": "^3.0.0",
    "commander": "^12.0.0",
    "form-data": "^4.0.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^5.0.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pdf",
    "parser",
    "ocr",
    "text-extraction",
    "pdf-to-text",
    "document-parsing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/run-llama/liteparse.git"
  },
  "bugs": {
    "url": "https://github.com/run-llama/liteparse/issues"
  },
  "homepage": "https://github.com/run-llama/liteparse#readme",
  "author": "",
  "license": "Apache-2.0"
}