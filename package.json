{
  "name": "@llamaindex/liteparse",
  "version": "1.4.0",
  "description": "Open-source PDF parsing with spatial text extraction and OCR processing",
  "type": "module",
  "main": "./dist/src/lib.js",
  "types": "./dist/src/lib.d.ts",
  "bin": {
    "lit": "./dist/src/index.js",
    "liteparse": "./dist/src/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/lib.d.ts",
      "import": "./dist/src/lib.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/vendor/pdfjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-vendor",
    "build:windows": "tsc && npm run copy-vendor:windows",
    "copy-vendor": "mkdir -p dist/src/vendor && cp -r src/vendor/pdfjs dist/src/vendor/",
    "copy-vendor:windows": "powershell -Command \"New-Item -ItemType Directory -Path dist/src/vendor -Force; Copy-Item -Recurse src/vendor/pdfjs dist/src/vendor/\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src cli",
    "lint:fix": "eslint src cli --fix",
    "format": "prettier --write \"src/**/*.ts\" \"cli/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"cli/**/*.ts\"",
    "docs:api": "bash scripts/generate-api-docs.sh",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "dependencies": {
    "@hyzyla/pdfium": "^2.1.9",
    "axios": "^1.7.0",
    "commander": "^12.0.0",
    "file-type": "^21.3.3",
    "form-data": "^4.0.0",
    "p-limit": "^7.3.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "unified": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "pdf",
    "parser",
    "ocr",
    "text-extraction",
    "pdf-to-text",
    "document-parsing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/run-llama/liteparse.git"
  },
  "bugs": {
    "url": "https://github.com/run-llama/liteparse/issues"
  },
  "homepage": "https://github.com/run-llama/liteparse#readme",
  "author": "LlamaIndex",
  "license": "Apache-2.0"
}
